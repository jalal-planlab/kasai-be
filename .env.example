PORT=7002
NODE_ENV=production

# Required in production (comma-separated, no wildcards)
CORS_ORIGIN=https://your-frontend-domain.com

# Set true (or hop count) when behind nginx, Railway, Render, etc.
TRUST_PROXY=true

# Rate limits (optional — defaults shown)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=100
# BOOKING_RATE_LIMIT_WINDOW_MS=3600000
# BOOKING_RATE_LIMIT_MAX=5

# SMTP (Gmail, SendGrid SMTP, Mailtrap, etc.)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
# Gmail app passwords: use quotes, spaces optional (e.g. "abcd efgh ijkl mnop")
SMTP_PASS="your-app-password"
EMAIL_FROM="Kasai Online <your@gmail.com>"
BOOKING_NOTIFY_EMAIL=owner@example.com

# Development example:
# NODE_ENV=development
# CORS_ORIGIN=http://localhost:5173
